generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String                    @id @default(uuid()) @db.Uuid
  firebaseUid            String                    @unique @map("firebase_uid") @db.VarChar(128)
  email                  String                    @unique @db.VarChar(255)
  fullName               String                    @map("full_name") @db.VarChar(255)
  role                   UserRole
  phone                  String?                   @db.VarChar(20)
  avatarUrl              String?                   @map("avatar_url")
  status                 UserStatus                @default(ACTIVE)
  age                    Int?
  allergies              String?
  snackAuthorized        Boolean                   @default(false) @map("snack_authorized")
  snackPunches           Int                       @default(0) @map("snack_punches")
  seashells              Int                       @default(0) @map("prize_points")
  // Step Up for Students' own internal ID for this student (from the "STUDENT
  // ID" column of their CSV export) — stable per student across submissions,
  // so once learned it's a much more reliable EMA match than comparing names.
  emaStudentId           String?                   @unique @map("ema_student_id") @db.VarChar(50)
  createdAt              DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                  @updatedAt @map("updated_at") @db.Timestamptz(6)
  baseSalary             Decimal?                  @map("base_salary") @db.Decimal(10, 2)
  perSessionRate         Decimal?                  @map("per_session_rate") @db.Decimal(10, 2)
  accommodationNotes     String?                   @map("accommodation_notes")
  medicalNotes           String?                   @map("medical_notes")
  authoredAnnouncements  Announcement[]
  attendance             Attendance[]
  behaviorLogsAsStudent  BehaviorLog[]             @relation("StudentBehaviors")
  behaviorLogsAsTeacher  BehaviorLog[]             @relation("TeacherBehaviors")
  sentMessages           ChatMessage[]
  chatParticipations     ChatParticipant[]
  enrollments            ClassEnrollment[]
  fitReportsAsReviewer   ClassFitReport[]          @relation("ReviewerFitReports")
  fitReportsAsStudent    ClassFitReport[]          @relation("StudentFitReports")
  fitReportsAsTeacher    ClassFitReport[]          @relation("TeacherFitReports")
  taughtClasses          Class[]                   @relation("TeacherClasses")
  familyMembers          FamilyMember[]
  marketingSubmissions   MarketingSubmission[]     @relation("TeacherSubmissions")
  materials              Material[]
  notifPreferences       NotificationPreference[]
  notifications          Notification[]
  recordedPayments       Payment[]                 @relation("RecordedByUser")
  priorityHolds          PriorityHold[]
  prizeHistory           PrizeHistory[]
  registrationReqs       RegistrationRequest[]
  regAlertsAsReporter    ClassAlert[]              @relation("ReporterAlerts")
  regAlertsAsResolver    ClassAlert[]              @relation("ResolverAlerts")
  regAlertsAsStudent     ClassAlert[]              @relation("StudentAlerts")
  scholarships           ScholarshipDisbursement[]
  snackPurchases         SnackPurchase[]
  transactions           Transaction[]
  waitlistEntries        WaitlistEntry[]
  fcmToken               String?                   @map("fcm_token")
  quietHoursStart        String?                   @map("quiet_hours_start") @db.VarChar(10)
  quietHoursEnd          String?                   @map("quiet_hours_end") @db.VarChar(10)
  autoResponderMessage   String?                   @map("auto_responder_message")
  announcementReads      AnnouncementRead[]
  medicalLogsAsStudent   MedicalLog[]              @relation("StudentMedicalLogs")
  medicalLogsAsTeacher   MedicalLog[]              @relation("TeacherMedicalLogs")
  medicalLogsAsReviewer  MedicalLog[]              @relation("ReviewerMedicalLogs")
  lessonPlans            LessonPlan[]              @relation("TeacherLessonPlans")
  supplyItems            SupplyItem[]
  timeOffRequests        TimeOffRequest[]
  spaceReservations      SpaceReservation[]
  tempPickupAuths        TempPickupAuth[]
  assignments            Assignment[]              @relation("TeacherAssignments")
  grades                 Grade[]                   @relation("StudentGrades")
  cancellationsAsStudent SessionCancellation[]     @relation("StudentCancellations")
  cancellationsReported  SessionCancellation[]     @relation("CancelledByStaff")
  cancellationsResolved  SessionCancellation[]     @relation("ResolvedByStaff")
  snackReloadsAsStudent  SnackReloadRequest[]      @relation("SnackReloadStudent")
  snackReloadsDecided    SnackReloadRequest[]      @relation("SnackReloadDecidedBy")
  snackReloadsFulfilled  SnackReloadRequest[]      @relation("SnackReloadFulfilledBy")

  @@map("users")
}

model Family {
  id           String                    @id @default(uuid()) @db.Uuid
  name         String                    @db.VarChar(255)
  tags         String[]                  @default([])
  createdAt    DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  members      FamilyMember[]
  invoices     Invoice[]
  payments     Payment[]
  scholarships ScholarshipDisbursement[]
  transactions Transaction[]
  snackReloads SnackReloadRequest[]

  @@map("families")
}

model FamilyMember {
  id                 String  @id @default(uuid()) @db.Uuid
  familyId           String  @map("family_id") @db.Uuid
  userId             String  @map("user_id") @db.Uuid
  role               String? @db.VarChar(50)
  isInvoiceRecipient Boolean @default(false) @map("is_invoice_recipient")
  family             Family  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@map("family_members")
}

model Class {
  id               String                @id @default(uuid()) @db.Uuid
  name             String                @db.VarChar(255)
  subject          String?               @db.VarChar(100)
  teacherId        String?               @map("teacher_id") @db.Uuid
  type             ClassType             @default(IN_PERSON)
  groupType        GroupType             @default(REGULAR) @map("group_type")
  meetingUrl       String?               @map("meeting_url")
  maxStudents      Int                   @default(10) @map("max_students")
  status           String                @default("active") @db.VarChar(20)
  termId           String?               @map("term_id") @db.Uuid
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  enrollments      ClassEnrollment[]
  classFitReports  ClassFitReport[]
  teacher          User?                 @relation("TeacherClasses", fields: [teacherId], references: [id])
  term             RegistrationTerm?     @relation("TermClasses", fields: [termId], references: [id])
  priorityHolds    PriorityHold[]
  firstChoiceReqs  RegistrationRequest[] @relation("FirstChoice")
  secondChoiceReqs RegistrationRequest[] @relation("SecondChoice")
  sessions         Session[]
  waitlistEntries  WaitlistEntry[]
  lessonPlans      LessonPlan[]
  assignments      Assignment[]

  @@map("classes")
}

model ClassEnrollment {
  id         String   @id @default(uuid()) @db.Uuid
  classId    String   @map("class_id") @db.Uuid
  studentId  String   @map("student_id") @db.Uuid
  enrolledAt DateTime @default(now()) @map("enrolled_at") @db.Timestamptz(6)
  status     String   @default("active") @db.VarChar(20)
  class      Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@map("class_enrollments")
}

model Session {
  id              String                @id @default(uuid()) @db.Uuid
  classId         String                @map("class_id") @db.Uuid
  date            DateTime              @db.Date
  startTime       DateTime              @map("start_time") @db.Time(6)
  endTime         DateTime              @map("end_time") @db.Time(6)
  status          SessionStatus         @default(SCHEDULED)
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  attendance      Attendance[]
  behaviorLogs    BehaviorLog[]
  classFitReports ClassFitReport[]
  materials       SessionMaterial[]
  notes           SessionNote[]
  cancellations   SessionCancellation[]
  class           Class                 @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
  @@index([date])
  @@map("sessions")
}

// Tracks a single student's cancellation of a scheduled session against the
// 48-hour policy: >=48h out is free (auto-resolved, no charge); <48h suggests
// a 50% charge but the admin must review and set the final amount — this
// model IS that review queue, surfaced in Front Desk Alerts.
model SessionCancellation {
  id                     String    @id @default(uuid()) @db.Uuid
  sessionId              String    @map("session_id") @db.Uuid
  studentId              String    @map("student_id") @db.Uuid
  cancelledById          String    @map("cancelled_by") @db.Uuid
  reason                 String?
  hoursBeforeClass       Decimal   @map("hours_before_class") @db.Decimal(6, 2)
  suggestedChargePercent Int       @map("suggested_charge_percent")
  status                 String    @default("PENDING_REVIEW") @db.VarChar(20) // PENDING_REVIEW | RESOLVED
  finalChargePercent     Int?      @map("final_charge_percent")
  chargeAmount           Decimal?  @map("charge_amount") @db.Decimal(10, 2)
  resolvedById           String?   @map("resolved_by") @db.Uuid
  resolvedAt             DateTime? @map("resolved_at") @db.Timestamptz(6)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  session     Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student     User    @relation("StudentCancellations", fields: [studentId], references: [id], onDelete: Cascade)
  cancelledBy User    @relation("CancelledByStaff", fields: [cancelledById], references: [id])
  resolvedBy  User?   @relation("ResolvedByStaff", fields: [resolvedById], references: [id])

  @@unique([sessionId, studentId])
  @@index([status])
  @@map("session_cancellations")
}

model Attendance {
  id        String           @id @default(uuid()) @db.Uuid
  sessionId String           @map("session_id") @db.Uuid
  studentId String           @map("student_id") @db.Uuid
  status    AttendanceStatus @default(PRESENT)
  checkedAt DateTime         @default(now()) @map("checked_at") @db.Timestamptz(6)
  session   Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student   User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([sessionId, studentId])
  @@index([studentId])
  @@map("attendance")
}

model SessionNote {
  id           String   @id @default(uuid()) @db.Uuid
  sessionId    String   @map("session_id") @db.Uuid
  notes        String?
  visibility   String   @default("all") @db.VarChar(20)
  recordingUrl String?  @map("recording_url")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_notes")
}

model SessionMaterial {
  id         String   @id @default(uuid()) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  name       String   @db.VarChar(255)
  fileUrl    String   @map("file_url")
  fileType   String?  @map("file_type") @db.VarChar(50)
  uploadedAt DateTime @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_materials")
}

model Material {
  id         String   @id @default(uuid()) @db.Uuid
  studentId  String   @map("student_id") @db.Uuid
  name       String   @db.VarChar(255)
  subject    String?  @db.VarChar(100)
  type       String?  @db.VarChar(50)
  fileUrl    String   @map("file_url")
  date       DateTime @default(now()) @db.Date
  uploadedAt DateTime @default(now()) @map("uploaded_at") @db.Timestamptz(6)
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("materials")
}

model SnackItem {
  id          String          @id @default(uuid()) @db.Uuid
  name        String          @db.VarChar(255)
  costPunches Int             @map("cost_punches")
  imageUrl    String?         @map("image_url")
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  purchases   SnackPurchase[]

  @@map("snack_items")
}

model SnackPurchase {
  id          String    @id @default(uuid()) @db.Uuid
  studentId   String    @map("student_id") @db.Uuid
  snackId     String    @map("snack_id") @db.Uuid
  punchesUsed Int       @map("punches_used")
  purchasedAt DateTime  @default(now()) @map("purchased_at") @db.Timestamptz(6)
  snack       SnackItem @relation(fields: [snackId], references: [id])
  student     User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("snack_purchases")
}

// A parent-approval request raised the moment a student's snack card hits 0.
// The parent approves/rejects reloading more (paid) punches; front desk only
// tops up + charges once the parent has approved. See rewards.controller.js.
//   PENDING   → created on depletion, awaiting the parent's decision
//   APPROVED  → parent authorized the reload; visible in the front-desk queue
//   REJECTED  → parent declined; nothing charged
//   FULFILLED → front desk added the punches and recorded the CHARGE
model SnackReloadRequest {
  id            String    @id @default(uuid()) @db.Uuid
  studentId     String    @map("student_id") @db.Uuid
  familyId      String?   @map("family_id") @db.Uuid
  punchCount    Int       @map("punch_count")
  price         Decimal   @db.Decimal(10, 2)
  status        String    @default("PENDING") @db.VarChar(20)
  triggeredById String?   @map("triggered_by") @db.Uuid
  decidedById   String?   @map("decided_by") @db.Uuid
  decidedAt     DateTime? @map("decided_at") @db.Timestamptz(6)
  fulfilledById String?   @map("fulfilled_by") @db.Uuid
  fulfilledAt   DateTime? @map("fulfilled_at") @db.Timestamptz(6)
  transactionId String?   @map("transaction_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  student     User    @relation("SnackReloadStudent", fields: [studentId], references: [id], onDelete: Cascade)
  family      Family? @relation(fields: [familyId], references: [id])
  decidedBy   User?   @relation("SnackReloadDecidedBy", fields: [decidedById], references: [id])
  fulfilledBy User?   @relation("SnackReloadFulfilledBy", fields: [fulfilledById], references: [id])

  @@index([status])
  @@index([studentId])
  @@map("snack_reload_requests")
}

model PrizeHistory {
  id        String    @id @default(uuid()) @db.Uuid
  studentId String    @map("student_id") @db.Uuid
  reason    String    @db.VarChar(255)
  points    Int
  type      PrizeType
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  student   User      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("prize_history")
}

model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  studentId   String?         @map("student_id") @db.Uuid
  familyId    String?         @map("family_id") @db.Uuid
  amount      Decimal         @db.Decimal(10, 2)
  type        TransactionType
  description String?
  date        DateTime        @default(now()) @db.Date
  invoiceId   String?         @map("invoice_id") @db.Uuid
  paymentId   String?         @map("payment_id") @db.Uuid
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  family      Family?         @relation(fields: [familyId], references: [id])
  invoice     Invoice?        @relation(fields: [invoiceId], references: [id])
  payment     Payment?        @relation(fields: [paymentId], references: [id])
  student     User?           @relation(fields: [studentId], references: [id])

  @@index([familyId])
  @@index([date])
  @@map("transactions")
}

model Invoice {
  id                  String        @id @default(uuid()) @db.Uuid
  invoiceNumber       String        @unique @map("invoice_number") @db.VarChar(20)
  familyId            String?       @map("family_id") @db.Uuid
  studentId           String?       @map("student_id") @db.Uuid
  date                DateTime      @default(now()) @db.Date
  dateRange           String?       @map("date_range") @db.VarChar(100)
  poNumbers           String[]      @default([]) @map("po_numbers")
  source              String?       @db.VarChar(20)
  subtotal            Decimal       @db.Decimal(10, 2)
  processingFee       Decimal       @default(0) @map("processing_fee") @db.Decimal(10, 2)
  totalAmount         Decimal       @map("total_amount") @db.Decimal(10, 2)
  amountPaid          Decimal       @default(0) @map("amount_paid") @db.Decimal(10, 2)
  status              InvoiceStatus @default(DRAFT)
  dueDate             DateTime?     @map("due_date") @db.Date
  stripePaymentLink   String?       @map("stripe_payment_link")
  stripePaymentLinkId String?       @map("stripe_payment_link_id") @db.VarChar(255)
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  lines               InvoiceLine[]
  family              Family?       @relation(fields: [familyId], references: [id])
  payments            Payment[]
  transactions        Transaction[]

  @@index([familyId])
  @@index([status])
  @@map("invoices")
}

model InvoiceLine {
  id          String  @id @default(uuid()) @db.Uuid
  invoiceId   String  @map("invoice_id") @db.Uuid
  description String
  amount      Decimal @db.Decimal(10, 2)
  quantity    Int     @default(1)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_lines")
}

model Payment {
  id                    String                    @id @default(uuid()) @db.Uuid
  familyId              String?                   @map("family_id") @db.Uuid
  invoiceId             String?                   @map("invoice_id") @db.Uuid
  amount                Decimal                   @db.Decimal(10, 2)
  processingFee         Decimal                   @default(0) @map("processing_fee") @db.Decimal(10, 2)
  netAmount             Decimal?                  @map("net_amount") @db.Decimal(10, 2)
  method                PaymentMethod
  status                PaymentStatus             @default(PENDING)
  stripePaymentIntentId String?                   @map("stripe_payment_intent_id") @db.VarChar(255)
  stripeChargeId        String?                   @map("stripe_charge_id") @db.VarChar(255)
  stripeReceiptUrl      String?                   @map("stripe_receipt_url")
  externalReference     String?                   @map("external_reference") @db.VarChar(255)
  notes                 String?
  recordedById          String?                   @map("recorded_by") @db.Uuid
  paidAt                DateTime?                 @map("paid_at") @db.Timestamptz(6)
  createdAt             DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  // Wave accounting sync: set once the payment has been pushed to Wave as an
  // income money-transaction. waveTransactionId is Wave's transaction id; the
  // presence of waveSyncedAt is what makes a re-sync skip this payment.
  waveTransactionId     String?                   @map("wave_transaction_id") @db.VarChar(255)
  waveSyncedAt          DateTime?                 @map("wave_synced_at") @db.Timestamptz(6)
  family                Family?                   @relation(fields: [familyId], references: [id])
  invoice               Invoice?                  @relation(fields: [invoiceId], references: [id])
  recordedBy            User?                     @relation("RecordedByUser", fields: [recordedById], references: [id])
  scholarships          ScholarshipDisbursement[]
  transactions          Transaction[]

  @@index([waveSyncedAt])
  @@map("payments")
}

/// Single-row OAuth connection to the academy's Wave accounting business.
/// Stores encrypted access/refresh tokens plus the mapping of which Wave
/// accounts recorded income should be deposited into (anchor) and categorised
/// under (income). A missing row means "Wave is not connected".
model WaveConnection {
  id                 String    @id @default(uuid()) @db.Uuid
  // Wave business the tokens belong to.
  businessId         String?   @map("business_id") @db.VarChar(255)
  businessName       String?   @map("business_name") @db.VarChar(255)
  // AES-GCM encrypted OAuth tokens — never returned to the client.
  accessToken        String?   @map("access_token")
  refreshToken       String?   @map("refresh_token")
  tokenExpiresAt     DateTime? @map("token_expires_at") @db.Timestamptz(6)
  scope              String?   @db.VarChar(255)
  // Account mapping for income transactions (chosen by the admin post-connect).
  anchorAccountId    String?   @map("anchor_account_id") @db.VarChar(255)
  anchorAccountName  String?   @map("anchor_account_name") @db.VarChar(255)
  incomeAccountId    String?   @map("income_account_id") @db.VarChar(255)
  incomeAccountName  String?   @map("income_account_name") @db.VarChar(255)
  connectedById      String?   @map("connected_by") @db.Uuid
  connectedAt        DateTime? @map("connected_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("wave_connection")
}

model ScholarshipDisbursement {
  id         String             @id @default(uuid()) @db.Uuid
  familyId   String?            @map("family_id") @db.Uuid
  studentId  String?            @map("student_id") @db.Uuid
  program    ScholarshipProgram
  amount     Decimal            @db.Decimal(10, 2)
  period     String?            @db.VarChar(50)
  status     ScholarshipStatus  @default(PENDING)
  paymentId  String?            @map("payment_id") @db.Uuid
  receivedAt DateTime?          @map("received_at") @db.Timestamptz(6)
  createdAt  DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  family     Family?            @relation(fields: [familyId], references: [id])
  payment    Payment?           @relation(fields: [paymentId], references: [id])
  student    User?              @relation(fields: [studentId], references: [id])

  @@map("scholarship_disbursements")
}

model PaymentSettings {
  id                String   @id @default(uuid()) @db.Uuid
  stripeAccountId   String?  @map("stripe_account_id") @db.VarChar(255)
  passCcFeeToParent Boolean  @default(false) @map("pass_cc_fee_to_parent")
  ccFeePercentage   Decimal  @default(2.90) @map("cc_fee_percentage") @db.Decimal(4, 2)
  ccFeeFixed        Decimal  @default(0.30) @map("cc_fee_fixed") @db.Decimal(4, 2)
  acceptedMethods   String[] @default(["stripe_card", "paypal", "venmo", "zelle", "scholarship_fes", "scholarship_ema", "cash", "check"]) @map("accepted_methods")
  autoSendReceipt   Boolean  @default(true) @map("auto_send_receipt")
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("payment_settings")
}

model ChatThread {
  id           String            @id @default(uuid()) @db.Uuid
  name         String?           @db.VarChar(255)
  isBot        Boolean           @default(false) @map("is_bot")
  status       ChatThreadStatus  @default(ACTIVE)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  messages     ChatMessage[]
  participants ChatParticipant[]

  @@map("chat_threads")
}

model ChatParticipant {
  id         String     @id @default(uuid()) @db.Uuid
  threadId   String     @map("thread_id") @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  isBlocked  Boolean    @default(false) @map("is_blocked")
  joinedAt   DateTime   @default(now()) @map("joined_at") @db.Timestamptz(6)
  lastReadAt DateTime?  @map("last_read_at") @db.Timestamptz(6)
  thread     ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@map("chat_participants")
}

model ChatMessage {
  id          String     @id @default(uuid()) @db.Uuid
  threadId    String     @map("thread_id") @db.Uuid
  senderId    String?    @map("sender_id") @db.Uuid
  text        String
  fileUrl     String?    @map("file_url")
  fileName    String?    @map("file_name")
  fileType    String?    @map("file_type") @db.VarChar(100)
  // Drive is the durable copy — local disk on Render is wiped on every
  // restart, so the attachment is served from Drive whenever this is set.
  driveFileId String?    @map("drive_file_id") @db.VarChar(255)
  sentAt      DateTime   @default(now()) @map("sent_at") @db.Timestamptz(6)
  sender      User?      @relation(fields: [senderId], references: [id])
  thread      ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([sentAt])
  @@map("chat_messages")
}

model Notification {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  type          String    @db.VarChar(50)
