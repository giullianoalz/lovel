# ===========================================
# Academy Management System - Backend Config
# ===========================================

# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL via Neon or local)
# If using Neon with PgBouncer pooling:
DATABASE_URL="postgresql://user:password@ep-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# Direct (non-pooled) connection — required by Prisma Migrate (advisory locks not supported by PgBouncer)
DIRECT_URL="postgresql://user:password@ep-xxxxx.region.aws.neon.tech/neondb?sslmode=require"

# Firebase Admin SDK
# Download your service account key from:
# Firebase Console → Project Settings → Service Accounts → Generate New Private Key
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Stripe
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_signing_secret"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_publishable_key"

# Email (Resend)
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="noreply@youracademy.com"

# AI Chat Assistant (optional — falls back to Ollama if not set)
# AI_PROVIDER=claude  → uses Anthropic API (needs key below)
# AI_PROVIDER=ollama  → uses local Ollama (free, no key needed)
AI_PROVIDER="claude"
ANTHROPIC_API_KEY="sk-ant-your_anthropic_api_key_here"

# Frontend URL (for CORS & Stripe redirect)
FRONTEND_URL="http://localhost:5173"

# JWT Secret (backup, Firebase handles primary auth)
JWT_SECRET="your-fallback-jwt-secret-change-this"

# Google Drive — also the durable storage for marketing photos and chat
# attachments (Render's local disk is wiped on every restart/redeploy).
# Provide the Service Account credentials here for Google Drive upload
DRIVE_CLIENT_EMAIL="your-google-service-account@your-project.iam.gserviceaccount.com"
DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
DRIVE_MARKETING_FOLDER_ID="your-google-drive-folder-id"
DRIVE_CHAT_FOLDER_ID="your-google-drive-folder-id-for-chat-attachments"
